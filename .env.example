# Hermes Station environment overrides.
#
# This file is *not* auto-loaded by either Vite or the Python backend.
# The canonical source for every value below is ``~/.hermes/config.yaml``
# under ``platforms.station.extra.*``; set vars in your
# shell (``export HMS_PORT=...``) only when you need to override
# config.yaml at runtime — for example in CI, a one-off ``pnpm dev``
# invocation on a non-default port, or a container start command.
#
# Copy to ``.env`` and ``source .env`` if you want, but do NOT add
# ``HERMES_HOME=~/.hermes`` here: upstream's ``load_hermes_dotenv``
# would inject the literal ``~`` string into the process environment
# with ``override=True``, which used to manifest as a spurious
# ``./~/.hermes`` directory in CWD. ``server.lib.upstream_paths`` now
# expands defensively so this is harmless, but it's still noise.

# ── Station server ───────────────────────────────────────────────
# Bind host. ``0.0.0.0`` requires HMS_PASSWORD_HASH below or the
# settings panel will refuse to save with ``host_requires_password``.
HMS_HOST=127.0.0.1

# Listen port. Production: Python aiohttp serves the built SPA directly
# at this port. Dev: Vite (on 3131) reverse-proxies /api and /ws here.
HMS_PORT=1313

# Argon2id hash of the SPA login password. Generate with::
#
#     ~/.hermes/hermes-agent/venv/bin/python -c \
#       "from server.lib.argon2_hash import hash_password; \
#        print(hash_password(input('pw> ')))"
#
# Leave empty for localhost-trusted no-auth mode.
HMS_PASSWORD_HASH=

# Session cookie lifetime (seconds). Default 86400 = 24h. Minimum 60.
HMS_SESSION_TTL=86400

# Maximum concurrent agent runs. Independent of upstream's api_server
# cap; default aligned at 10.
HMS_MAX_CONCURRENT_RUNS=10

# Comma-separated extra origins permitted by CORS (in addition to the
# loopback variants). Only consulted when HMS_HOST=0.0.0.0.
HMS_CORS_ORIGINS=

# ── Upstream Dashboard ───────────────────────────────────────────────
# The Station does not run the Dashboard; it transparently proxies
# ``/api/dashboard/*`` to whatever is at this URL.
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Optional session token. Empty → use whatever upstream parsed from the
# ``dashboard:`` block in config.yaml.
HERMES_DASHBOARD_TOKEN=

# ── Dev launcher ─────────────────────────────────────────────────────
# Override the Python interpreter ``scripts/dev.sh`` picks. Useful in
# CI / when ``~/.hermes/hermes-agent/venv`` isn't installed in the
# conventional location.
# HMS_PYTHON=/path/to/python
